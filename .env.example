# =============================================================================
#  Sentro Self-Hosted — Environment Configuration
#  Copy to .env and fill in all REQUIRED values
# =============================================================================

# ── License ──────────────────────────────────────────────────
# Community edition (5 monitors, 1 member) = leave empty
# Paid editions: obtain from https://sentro.dev/self-hosting
SENTRO_LICENSE_KEY=

# Optional: phone-home license revocation check
# LICENSE_CHECK_URL=https://license.sentro.dev

# ── Image ─────────────────────────────────────────────────────
SENTRO_IMAGE_REGISTRY=ghcr.io/sentro-dev/platform
SENTRO_IMAGE_TAG=latest

# ── Domains ───────────────────────────────────────────────────
DOMAIN_APP=app.example.com
DOMAIN_ADMIN=admin.example.com
DOMAIN_API=api.example.com
# DOMAIN_DOCS=docs.example.com    # Only if using --profile docs

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=sentro
POSTGRES_PASSWORD=           # REQUIRED: openssl rand -hex 16
POSTGRES_DB=sentro

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=              # REQUIRED: openssl rand -hex 16

# ── Auth ──────────────────────────────────────────────────────
AUTH_SECRET=                 # REQUIRED: openssl rand -hex 32
AUTH_URL=https://app.example.com
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# ── Encryption ────────────────────────────────────────────────
ENCRYPTION_KEY=              # REQUIRED: openssl rand -hex 32 (64 hex chars)

# ── Admin Panel ───────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=              # REQUIRED: strong password
ADMIN_SESSION_SECRET=        # REQUIRED: openssl rand -hex 32

# ── API Server ────────────────────────────────────────────────
API_CORS_ORIGIN=https://app.example.com,https://admin.example.com

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── AI Assistant (optional) ───────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── SMS Alerts (optional) ─────────────────────────────────────
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ── Observability (optional — enable with --profile monitoring) ─
# GRAFANA_ADMIN_PASSWORD=changeme
# PROMETHEUS_METRICS_PORT=9464
